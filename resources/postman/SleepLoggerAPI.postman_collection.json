    {
      "name": "4 — Get 30-Day Averages",
      "item": [
        {
          "name": "4a. Happy path — Charlie (5 entries, mixed feelings)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Response has averages fields', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.averageTotalMinutesInBed).to.be.a('number');",
                  "  pm.expect(body.averageBedTime).to.be.a('string');",
                  "  pm.expect(body.averageWakeTime).to.be.a('string');",
                  "  pm.expect(body.startDate).to.be.a('string');",
                  "  pm.expect(body.endDate).to.eql(pm.variables.get('today'));",
                  "});",
                  "",
                  "pm.test('Feeling frequencies sum to 5', () => {",
                  "  const f = pm.response.json().feelingFrequencies;",
                  "  pm.expect(f.GOOD + f.OK + f.BAD).to.eql(5);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/3/sleep-logs/averages",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "3", "sleep-logs", "averages"]
            }
          }
        },
        {
          "name": "4b. Single entry — Alice (avg = single value)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 200 OK', () => pm.response.to.have.status(200));",
                  "",
                  "pm.test('Averages reflect single entry', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.averageTotalMinutesInBed).to.eql(492);",
                  "  pm.expect(body.feelingFrequencies.GOOD).to.eql(1);",
                  "  pm.expect(body.feelingFrequencies.BAD).to.eql(0);",
                  "  pm.expect(body.feelingFrequencies.OK).to.eql(0);",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/1/sleep-logs/averages",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1", "sleep-logs", "averages"]
