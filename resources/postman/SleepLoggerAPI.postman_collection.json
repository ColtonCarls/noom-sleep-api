{
  "info": {
    "name": "Sleep Logger API",
    "description": "Test collection for the Noom Sleep Logger take-home API.\nSeeded users: Alice (1), Bob (2), Charlie (3).\n\nTimestamps are generated dynamically so tests work regardless of the date they are run.",
    "schema": "https://schema.getpostman.com/json/collection/v2.1.0/collection.json"
  },
  "variable": [
    {
      "key": "baseUrl",
      "value": "http://localhost:8080"
    }
  ],
  "event": [
    {
      "listen": "prerequest",
      "script": {
        "type": "text/javascript",
        "exec": [
          "const now = new Date();",
          "",
          "function pad(n) { return String(n).padStart(2, '0'); }",
          "",
          "function dateStr(offset) {",
          "  const d = new Date(now);",
          "  d.setUTCDate(d.getUTCDate() + offset);",
          "  return d.getUTCFullYear() + '-' + pad(d.getUTCMonth()+1) + '-' + pad(d.getUTCDate());",
          "}",
          "",
          "pm.variables.set('today', dateStr(0));",
          "",
          "pm.variables.set('bed_today',  dateStr(-1) + 'T22:53:00Z');",
          "pm.variables.set('wake_today', dateStr(0)  + 'T07:05:00Z');",
          "",
          "pm.variables.set('bed_d0',  dateStr(-1) + 'T23:15:00Z');",
          "pm.variables.set('wake_d0', dateStr(0)  + 'T06:45:00Z');",
          "",
          "pm.variables.set('bed_d1',  dateStr(-2) + 'T22:30:00Z');",
          "pm.variables.set('wake_d1', dateStr(-1) + 'T07:00:00Z');",
          "",
          "pm.variables.set('bed_d2',  dateStr(-3) + 'T23:45:00Z');",
          "pm.variables.set('wake_d2', dateStr(-2) + 'T06:30:00Z');",
          "",
          "pm.variables.set('bed_d3',  dateStr(-4) + 'T22:00:00Z');",
          "pm.variables.set('wake_d3', dateStr(-3) + 'T07:15:00Z');",
          "",
          "pm.variables.set('bed_d4',  dateStr(-5) + 'T23:30:00Z');",
          "pm.variables.set('wake_d4', dateStr(-4) + 'T06:00:00Z');"
        ]
      }
    }
  ],
  "item": [
    {
      "name": "1 — Create Sleep Log",
      "item": [
        {
          "name": "1a. Happy path — create sleep log (Alice)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 201 Created', () => pm.response.to.have.status(201));",
                  "",
                  "pm.test('Response has correct fields', () => {",
                  "  const body = pm.response.json();",
                  "  pm.expect(body.id).to.be.a('number');",
                  "  pm.expect(body.feeling).to.eql('GOOD');",
                  "  pm.expect(body.totalMinutesInBed).to.eql(492);",
                  "  pm.expect(body.sleepDate).to.eql(pm.variables.get('today'));",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/1/sleep-logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1", "sleep-logs"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bedTime\": \"{{bed_today}}\",\n  \"wakeTime\": \"{{wake_today}}\",\n  \"feeling\": \"GOOD\"\n}"
            }
          }
        },
        {
          "name": "1b. Bad request — wake time before bed time",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400 Bad Request', () => pm.response.to.have.status(400));",
                  "",
                  "pm.test('Error message mentions wake time', () => {",
                  "  pm.expect(pm.response.json().message).to.include('Wake time must be after bed time');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/2/sleep-logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "2", "sleep-logs"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bedTime\": \"{{wake_today}}\",\n  \"wakeTime\": \"{{bed_today}}\",\n  \"feeling\": \"GOOD\"\n}"
            }
          }
        },
        {
          "name": "1c. Bad request — invalid feeling value",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400 Bad Request', () => pm.response.to.have.status(400));",
                  "",
                  "pm.test('Error message mentions invalid value', () => {",
                  "  pm.expect(pm.response.json().message).to.include('TERRIBLE');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/2/sleep-logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "2", "sleep-logs"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bedTime\": \"{{bed_today}}\",\n  \"wakeTime\": \"{{wake_today}}\",\n  \"feeling\": \"TERRIBLE\"\n}"
            }
          }
        },
        {
          "name": "1d. Conflict — duplicate sleep date (Alice)",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 409 Conflict', () => pm.response.to.have.status(409));",
                  "",
                  "pm.test('Error message mentions duplicate', () => {",
                  "  pm.expect(pm.response.json().message).to.include('already exists');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/1/sleep-logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "1", "sleep-logs"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bedTime\": \"{{bed_today}}\",\n  \"wakeTime\": \"{{wake_today}}\",\n  \"feeling\": \"BAD\"\n}"
            }
          }
        },
        {
          "name": "1e. Error — non-existent user",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 404 Not Found', () => pm.response.to.have.status(404));",
                  "",
                  "pm.test('Error message mentions user', () => {",
                  "  pm.expect(pm.response.json().message).to.include('9999');",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/9999/sleep-logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "9999", "sleep-logs"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bedTime\": \"{{bed_today}}\",\n  \"wakeTime\": \"{{wake_today}}\",\n  \"feeling\": \"OK\"\n}"
            }
          }
        },
        {
          "name": "1f. Bad request — missing required fields",
          "event": [
            {
              "listen": "test",
              "script": {
                "type": "text/javascript",
                "exec": [
                  "pm.test('Status is 400 Bad Request', () => pm.response.to.have.status(400));",
                  "",
                  "pm.test('Error message mentions missing field', () => {",
                  "  const msg = pm.response.json().message;",
                  "  pm.expect(msg.includes('wakeTime') || msg.includes('feeling')).to.be.true;",
                  "});"
                ]
              }
            }
          ],
          "request": {
            "method": "POST",
            "header": [
              { "key": "Content-Type", "value": "application/json" }
            ],
            "url": {
              "raw": "{{baseUrl}}/api/users/2/sleep-logs",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "2", "sleep-logs"]
            },
            "body": {
              "mode": "raw",
              "raw": "{\n  \"bedTime\": \"{{bed_today}}\"\n}"
            }
          }
        }
      ]
    },
    {
