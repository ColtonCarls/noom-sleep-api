          "request": {
            "method": "GET",
            "url": {
              "raw": "{{baseUrl}}/api/users/9999/sleep-logs/last-night",
              "host": ["{{baseUrl}}"],
              "path": ["api", "users", "9999", "sleep-logs", "last-night"]
            }
          }
        }
      ]
    },
